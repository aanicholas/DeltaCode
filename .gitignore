# ─── Python (Danger Zone scripts live under Content/Python) ──────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ─── Secrets — must never be committed (Hard Constraint #3) ──────────────────
.env
.env.*
*.pem
*.key
secrets.json
credentials.json
api_key.txt
DeltaCode.ini

# ─── Claude Code — local-only config / permissions ───────────────────────────
.claude/settings.local.json
